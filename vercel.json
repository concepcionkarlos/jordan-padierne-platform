{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "rewrites": [],
  "crons": [
    {
      "path": "/api/cron/reminders",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/cron/drip",
      "schedule": "0 16 * * *"
    }
  ],
  "headers": [
    {
      "source": "/admin/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ]
}
